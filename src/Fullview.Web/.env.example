# Copy to .env.local (gitignored) and fill in your own values.
# The API key itself is no longer a build-time value — the app prompts for it at
# runtime and stores it in localStorage. See docs/device-setup.md's
# "API authentication" section for where the API key comes from.

VITE_API_BASE_URL=https://<your-api-id>.execute-api.<your-region>.amazonaws.com
